from typing import Tuple, Dict, Any
from .models import Observation, Action, EnvState, Ticket

class SupportEnv:
    def __init__(self):
        self.state = EnvState(all_tickets=[], steps_taken=0, max_steps=15)
        self.current_task_id = None
        self.total_reward = 0.0

    def reset(self, task_config: Dict[str, Any] = None) -> Observation:
        task_config = task_config or {}
        tickets_data = task_config.get("tickets", [])
        self.state = EnvState(
            all_tickets=[Ticket(**t) for t in tickets_data],
            steps_taken=0,
            max_steps=task_config.get("max_steps", 15)
        )
        self.total_reward = 0.0
        return self._get_obs("Environment initialized.")

    def step(self, action: Action) -> Tuple[Observation, float, bool, Dict]:
        self.state.steps_taken += 1
        reward = -0.1 # Small step penalty to encourage efficiency
        feedback = ""

        ticket = next((t for t in self.state.all_tickets if t.id == action.ticket_id), None)
        
        if not ticket:
            feedback = f"Error: Ticket {action.ticket_id} not found."
            reward -= 0.5
        elif ticket.status == "CLOSED":
            feedback = f"Error: Ticket {action.ticket_id} is already closed."
            reward -= 0.5
        else:
            if action.action_type == "ROUTE":
                if not action.department:
                    feedback = "Error: Department required for ROUTE action."
                else:
                    ticket.assigned_dept = action.department
                    ticket.status = "ROUTED"
                    feedback = f"Ticket {ticket.id} routed to {action.department}."
                    reward += 1.0 # Partial reward for taking an action
            
            elif action.action_type == "REPLY_AND_CLOSE":
                if not action.reply_template:
                    feedback = "Error: Reply template required for REPLY_AND_CLOSE."
                else:
                    ticket.agent_reply = action.reply_template
                    ticket.status = "CLOSED"
                    feedback = f"Ticket {ticket.id} closed with template {action.reply_template}."
                    reward += 1.0

        self.total_reward += reward
        done = self.state.steps_taken >= self.state.max_steps or all(t.status == "CLOSED" for t in self.state.all_tickets)
        
        return self._get_obs(feedback), reward, done, {}

    def state_info(self) -> EnvState:
        return self.state

    def _get_obs(self, feedback: str) -> Observation:
        open_tickets = [t for t in self.state.all_tickets if t.status != "CLOSED"]
        return Observation(
            open_tickets=open_tickets,
            last_action_feedback=feedback,
            current_score=self.total_reward
        )
